{
  "info": {
    "name": "SubClub API",
    "_postman_id": "subclub-api-collection",
    "description": "Collection completa da API SubClub.\n\n**Fluxo recomendado:**\n1. Execute `Auth / Login Admin` → token salvo automaticamente em `adminToken`\n2. Crie um Account Plan, depois uma Account\n3. Execute `Auth / Login Tenant` com um usuário vinculado à account → token salvo em `tenantToken`\n4. Use as rotas de Customers, Plans, Products e Subscriptions",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "tenantToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('adminToken', json.token);",
                  "    console.log('adminToken salvo');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"adm@adm.com\",\n  \"password\": \"12345678\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('tenantToken', json.token);",
                  "    console.log('tenantToken salvo');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"usuario@tenant.com\",\n  \"password\": \"senha\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Account Plans",
      "description": "Planos de assinatura do SubClub (o que as accounts contratam). Requer token admin.",
      "item": [
        {
          "name": "Create Account Plan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Starter\",\n  \"description\": \"Plano inicial para pequenas cafeterias\",\n  \"price\": 99.90,\n  \"maxCustomers\": 100,\n  \"maxPlans\": 3,\n  \"maxProducts\": 10,\n  \"active\": true\n}"
            },
            "url": { "raw": "{{baseUrl}}/account-plans", "host": ["{{baseUrl}}"], "path": ["account-plans"] }
          }
        },
        {
          "name": "List Account Plans",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/account-plans", "host": ["{{baseUrl}}"], "path": ["account-plans"] }
          }
        },
        {
          "name": "Get Account Plan",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/account-plans/:id", "host": ["{{baseUrl}}"], "path": ["account-plans", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Update Account Plan",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Starter Plus\",\n  \"description\": \"Plano inicial atualizado\",\n  \"price\": 129.90,\n  \"maxCustomers\": 200,\n  \"maxPlans\": 5,\n  \"maxProducts\": 20,\n  \"active\": true\n}"
            },
            "url": { "raw": "{{baseUrl}}/account-plans/:id", "host": ["{{baseUrl}}"], "path": ["account-plans", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Delete Account Plan",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/account-plans/:id", "host": ["{{baseUrl}}"], "path": ["account-plans", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    },
